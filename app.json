{
  "expo": {
    "name": "SmartDose",
    "slug": "smartdose",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartdose",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.upeka_jayasri.smartdose"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e3a5f"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bde29d0a-3979-46d9-9bb3-3523d2c8b642"
      },
      "firebaseApiKey": "AIzaSyDwKN3AU90Q7RfgKLODmOwOkhQPZl9F4nY",
      "firebaseAuthDomain": "smartdose-dcd88.firebaseapp.com",
      "firebaseProjectId": "smartdose-dcd88",
      "firebaseStorageBucket": "smartdose-dcd88.firebasestorage.app",
      "firebaseMessagingSenderId": "154127731250",
      "firebaseAppId": "1:154127731250:web:fa5501a8740dcb93ee8a2b",
      "firebaseDatabaseUrl": "https://smartdose-dcd88-default-rtdb.firebaseio.com"
    }
  }
}
